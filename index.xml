&lt;div class=&#34;highlight&#34;&gt;&lt;pre tabindex=&#34;0&#34; class=&#34;chroma&#34;&gt;&lt;code class=&#34;language-cmd&#34; data-lang=&#34;cmd&#34;&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;&lt;span class=&#34;k&#34;&gt;copy&lt;/span&gt; /b &lt;span class=&#34;s2&#34;&gt;&amp;#34;图片地址&amp;#34;&lt;/span&gt; + &lt;span class=&#34;s2&#34;&gt;&amp;#34;压缩包地址&amp;#34;&lt;/span&gt; &lt;span class=&#34;s2&#34;&gt;&amp;#34;导出路径与文件名&amp;#34;&lt;/span&gt;
